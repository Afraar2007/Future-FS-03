{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "orderly-eats/dist",
  "builds": [
    {
      "src": "orderly-eats/dist/server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "orderly-eats/dist/server/server.js"
    }
  ]
}